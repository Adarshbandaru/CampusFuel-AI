# ──────────────────────────────────────────────────────────────
# CampusFuel AI — Frontend Environment Variables
# Copy this file to .env and fill in your actual values.
# ──────────────────────────────────────────────────────────────

# Firebase Web SDK API key (from Firebase Console → Project Settings)
EXPO_PUBLIC_FIREBASE_API_KEY=your_api_key_here

# Firebase Auth domain (usually: <project-id>.firebaseapp.com)
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com

# Firebase project ID
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_project_id

# Firebase Cloud Storage bucket (usually: <project-id>.appspot.com)
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com

# Firebase Cloud Messaging sender ID
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000

# Firebase app ID (from Firebase Console → Project Settings → Your Apps)
EXPO_PUBLIC_FIREBASE_APP_ID=1:000000000000:android:xxxxxxxxxxxxxxxx

# Environment: development | staging | production
EXPO_PUBLIC_ENV=development

# Your machine's local IP address for device testing (development only)
# Find it with: ipconfig (Windows) or ifconfig (Mac/Linux)
EXPO_PUBLIC_DEV_IP=192.168.1.100
